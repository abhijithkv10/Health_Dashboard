# AWS Monitor - Environment Configuration
# Copy this to .env and fill in your values

# PostgreSQL connection string (production: RDS endpoint)
DB_CONNECTION=Host=localhost;Database=aws_monitor;Username=postgres;Password=your_password

# API key for /api/metrics/push endpoint
MONITOR_API_KEY=generate-a-random-secret-key

# AWS Configuration
AWS_REGION=us-east-1
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:monitor-alerts

# Admin credentials for the web dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# JWT secret (32+ characters)
JWT_SECRET=replace-with-a-random-secret-at-least-32-chars-long
